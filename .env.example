# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/satbridge

# ── API Server ────────────────────────────────────────────────────────────
# Port for the Express API server (default: 5000)
API_PORT=5000

# ── Mockup Sandbox (Vite dev server) ─────────────────────────────────────
# Port for the Vite dev server
PORT=8081
# Base path prefix for the mockup sandbox
BASE_PATH=/

# ── Auth (optional — only if ENABLE_AUTH=true) ────────────────────────────
# ENABLE_AUTH=true
# JWT_SECRET=your-jwt-secret-here

# ── ML Backend (bah2026-challenge11) ─────────────────────────────────────
# Supabase URL and service-role key for the ML backend
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key

# Redis (optional — ML backend falls back to in-memory cache without it)
# REDIS_URL=redis://localhost:6379

# Weights & Biases API key (optional — for training experiment tracking)
# WANDB_API_KEY=your-wandb-key
